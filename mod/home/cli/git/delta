[core]
  pager = delta
[delta]
  syntax-theme                  = "ansi"
  commit-style                  = raw
  file-style                    = "{{ colors.blue }}"
  hunk-header-style             = syntax
  minus-style                   = italic "{{ colors.red }}" "{{ colors.background }}"
  minus-emph-style              = reverse bold "{{ colors.red | stronger }}" "{{ colors.background }}"
  minus-non-emph-style          = "{{ colors.red }}" "{{ colors.background }}"
  minus-empty-line-marker-style = normal "{{ colors.red }}"
  zero-style                    = "{{ colors.foreground }}"
  plus-style                    = italic bold "{{ colors.green }}" "{{ colors.background }}"
  plus-emph-style               = reverse "{{ colors.green | stronger }}" "{{ colors.background }}"
  plus-non-emph-style           = italic bold "{{ colors.green }}" "{{ colors.background }}"
  plus-empty-line-marker-style  = normal "{{ colors.green }}"
  grep-file-style               = "{{ colors.blue }}"
  grep-line-number-style        = "{{ colors.blue }}"
  whitespace-error-style        = reverse "{{ colors.magenta | stronger }}"
  blame-colors                 = {{ colors.background_alt1 }} {{ colors.grey2 }} {{ colors.grey4 }}
