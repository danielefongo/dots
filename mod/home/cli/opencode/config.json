{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.5",
  "share": "disabled",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.yaml": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "ask",
      "*.elm": "allow",
      "*.lua": "allow",
      "*.md": "allow",
      "*.nix": "allow",
      "*.py": "allow",
      "*.rs": "allow",
      "Cargo.toml": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "*": "ask",
      "rm *": "deny"
    },
    "skill": {
      "*": "ask",
      "caveman*": "allow"
    },
    "lsp": "allow",
    "question": "allow",
    "todowrite": "allow"
  }
}
